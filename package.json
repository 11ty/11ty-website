{
  "name": "@11ty/website",
  "version": "2.0.0",
  "private": true,
  "description": "The website at 11ty.dev",
  "type": "module",
  "engines": {
    "node": ">=22.15"
  },
  "scripts": {
    "check-links": "npx check-html-links _site",
    "build": "npx @11ty/eleventy --quiet && npm run create-search-index",
    "build-production": "npm run get-new-data && NODE_ENV=production npx @11ty/eleventy && npm run create-search-index",
    "start": "npx @11ty/eleventy --serve --quiet --port=8091 --incremental",
    "start-production": "NODE_ENV=production npx @11ty/eleventy --serve --quiet --port=8091",
    "create-search-index": "npx pagefind --site \"_site\" --glob \"{docs,blog}/**/*.html\"",
    "get-new-data": "rm -rf ./src/_data/builtwith/ && npx degit github:11ty/11ty-community/built-with-eleventy src/_data/builtwith/",
    "format": "prettier --write '**/*.{js,css,html,md}'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/11ty/docs.git"
  },
  "author": "Zach Leatherman (https://zachleat.com/)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/11ty/docs/issues"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/11ty"
  },
  "homepage": "https://github.com/11ty/docs#readme",
  "lint-staged": {
    "*.{js,css,md}": [
      "prettier --write",
      "git add"
    ]
  },
  "devDependencies": {
    "@11ty/eleventy": "4.0.0-alpha.10",
    "@11ty/eleventy-activity-feed": "^2.0.0",
    "@11ty/eleventy-fetch": "^5.1.3",
    "@11ty/eleventy-img": "7.0.0-alpha.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@11ty/eleventy-plugin-webc": "^0.12.0-beta.7",
    "@11ty/font-awesome": "^1.0.1",
    "@11ty/image-color": "^1.0.8",
    "@sindresorhus/slugify": "^3.0.0",
    "@tweetback/canonical": "^2.0.48",
    "comma-number": "^2.1.0",
    "degit": "^2.8.6",
    "dotenv": "^17.4.2",
    "entities": "^8.0.0",
    "esbuild": "^0.28.1",
    "esm-import-transformer": "^3.0.5",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.6",
    "human-readable-numbers": "0.9.5",
    "lightningcss": "^1.32.0",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "markdown-it-table-of-contents": "^0.9.0",
    "memoize": "^10.2.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.4",
    "semver": "^7.8.5",
    "short-hash": "^1.0.0",
    "terser": "^5.48.0"
  },
  "dependencies": {
    "@11ty/client": "4.0.0-alpha.9",
    "@11ty/is-land": "^5.0.1",
    "@11ty/logo": "^3.0.0",
    "@awesome.me/webawesome": "^3.10.0",
    "@zachleat/details-utils": "^2.0.2",
    "@zachleat/filter-container": "^4.0.0",
    "@zachleat/flex-luthor": "^4.0.2",
    "@zachleat/heading-anchors": "^1.0.5",
    "@zachleat/line-numbers": "^1.0.3",
    "@zachleat/seven-minute-tabs": "^3.0.3",
    "artificial-chart": "^2.0.3",
    "lite-youtube-embed": "^0.3.4",
    "speedlify-score": "^4.0.4"
  },
  "overrides": {
    "@11ty/eleventy-img": "7.0.0-alpha.4"
  }
}
