{%- set goldSponsors = opencollective.supporters | opencollectiveTier("gold-sponsor") | filterSupportersActive %}
<div class="fl">
{%- if goldSponsors.length > 0 %}
	<div class="supporters-tiered supporters-gold">
		<h3 class="subhed"><strong>Gold Sponsors</strong></h3>
		<div class="lo-grid">
		{%- for supporter in goldSponsors | shuffle %}
		{%- set nameToSlug = supporter.name | slugify | lower -%}
			<div>
				<a href="{{ supporter.website or supporter.profile }}" class="elv-externalexempt" rel="sponsored">{% opencollectiveavatar supporter %}{{ supporter.name }}</a>
			</div>
		{%- endfor %}
		</div>
	</div>
{%- endif %}
	<div class="supporters-tiered supporters-silver">
		<h3 class="subhed"><strong>{% if goldSponsors.length > 0 %}Silver {% endif %}Sponsors</strong></h3>
		<div class="facepile facepile-supporters">
		{%- for supporter in opencollective.supporters | filterSupportersActive | shuffle %}{% if supporter.tier.slug == "silver-sponsor" -%}
			<a href="{{ supporter.website or supporter.profile }}" class="elv-externalexempt" rel="sponsored">{% opencollectiveavatar supporter %}</a>
		{%- endif %}{% endfor %}
		</div>
	</div>
</div>
<div class="fullwidth-module supporters-untiered">
	<is-land on:visible on:save-data="false">
		<template data-island>
			<h3 class="subhed ta-c"><a href="https://opencollective.com/11ty"><strong>{% if opencollective.backersCount %}×{{ opencollective.backersCount }} {% endif %}Supporters</strong></a></h3>
			<html-fetch src="/imports/supporters.html"></html-fetch>
		</template>
	</is-land>
</div>
