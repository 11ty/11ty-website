<script webc:setup>
export function latestVersionNodeMinimum(versions, config) {
	for( let version of versions ) {
		if(version.latestStableRelease) {
			return version.minimumNodeVersion;
		}
	}
	throw new Error("Latest stable release not found.");
}
</script>

<span webc:nokeep @text="latestVersionNodeMinimum($data.versions, $data.config)"></span>